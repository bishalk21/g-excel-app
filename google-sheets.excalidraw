    {
      "id": "gbglJQfyYkPm3NqFJvkrS",
      "type": "text",
      "x": -17801.281316501478,
      "y": -14983.4124147337,
      "width": 1783.9759318033891,
      "height": 650.9984334310063,
      "angle": 0,
      "strokeColor": "#1971c2",
