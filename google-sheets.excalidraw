      "isDeleted": true,
      "boundElements": [],
      "updated": 1773637147437,
      "link": null,
      "locked": false,
      "text": "// this is not a secure way to evaluate\nformulas, and should be used with caution. In\na production application, consider using a\nlibrary like mathjs or implementing a custom\nparser to safely evaluate formulas without\nexposing security risks.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// this is not a secure way to evaluate formulas, and should be used with caution. In a production application, consider using a library like mathjs or implementing a custom parser to safely evaluate formulas without exposing security risks.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "nxuVlqsxRf9GA2sSFlyUE",
      "type": "text",
      "x": -9153.458369575515,
      "y": 5763.052680786293,
      "width": 773.927734375,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c7ET",
      "roundness": null,
      "seed": 1890670598,
      "version": 3,
      "versionNonce": 1895796806,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773637147437,
      "link": null,
      "locked": false,
      "text": "// we can use tokenization and parsing\ntechniques to safely evaluate formulas,\nensuring that only valid operations and\nfunctions are allowed, and preventing the\nexecution of arbitrary code. This can be\nachieved by implementing a custom parser\nthat checks the syntax and semantics of\nthe formula before evaluating it, or by using\na library that provides secure formula\nevaluation capabilities.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// we can use tokenization and parsing techniques to safely evaluate formulas, ensuring that only valid operations and functions are allowed, and preventing the execution of arbitrary code. This can be achieved by implementing a custom parser that checks the syntax and semantics of the formula before evaluating it, or by using a library that provides secure formula evaluation capabilities.",
      "autoResize": false,
      "lineHeight": 1.25
    },
