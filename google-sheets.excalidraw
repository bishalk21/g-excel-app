      "versionNonce": 1617872454,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773630240735,
      "link": null,
      "locked": false,
      "text": "Approach 1: \n- create set to store visited nodes\n- traverse the linked list\n- if the curr node is in the set, cycle detected\n  - return true\n- if the end of list is reached, no cycle\n  - return false",
      "fontSize": 74.39982096354359,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
